## Django core
SECRET_KEY=replace-with-a-strong-random-value
DEBUG=True
DJANGO_ENV=development
DJANGO_TIME_ZONE=America/Chicago

## Database
# Local development database (used when DJANGO_ENV != production)
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5432/jobeas_local
# Production database URL (used when DJANGO_ENV=production)
DATABASE_URL_PROD=postgresql://user:password@host:5432/dbname

## Redis / Channels (optional in local)
REDIS_URL=redis://localhost:6379/0

## OpenAI
OPENAI_API_KEY=sk-...

## Email / notifications
SENDGRID_MAIL_ACCESS=SG...
FROM_EMAIL=JOBEAS <support@jobeas.com>
ADMIN_EMAIL=admin@jobeas.com
SITE_URL=http://localhost:8000
EMAIL_TEST_RECIPIENT=you@example.com

## Stripe
MYAPP_STRIPE_SECRET_KEY=sk_test_...
MYAPP_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_BILLING_CURRENCY=mxn

# Optional FX display hints used by subscriptions pricing display
# Example: if 1 MXN ~= 0.074 CAD and 0.059 USD
PRICING_APPROX_CAD_PER_MXN=
PRICING_APPROX_USD_PER_MXN=

# Optional Stripe catalog provisioning command vars
STRIPE_DESTINATION_SECRET_KEY=sk_test_...
STRIPE_SOURCE_SECRET_KEY=sk_test_...
STRIPE_PROVISION_CURRENCY=mxn
