## Django core
SECRET_KEY=replace-with-a-strong-random-value
DEBUG=True
DJANGO_ENV=development
DJANGO_TIME_ZONE=America/Chicago

## Database
# Local development database (used when DJANGO_ENV != production)
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5432/jobeas_local
# Production database URL (used when DJANGO_ENV=production)
DATABASE_URL_PROD=postgresql://user:password@host:5432/dbname
# Idle connection lifetime in seconds (Django persistent connections). Use 0 on Cloud Run to reduce Postgres connection spikes; default 600 if unset.
DATABASE_CONN_MAX_AGE=600

## Redis / Channels (optional in local)
REDIS_URL=redis://localhost:6379/0

## OpenAI
OPENAI_API_KEY=sk-...

## Google Gemini (resume–job evaluation — see ai_service/docs/AI_PLATFORM.md)
# Production: set ONE of these. Model + temperature are configured in Django admin
# (AI models + AI Prompt Configurations), not via env.
# Developer API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional alias (used if GEMINI_API_KEY is empty)
GOOGLE_API_KEY=

# Optional fallbacks only — used when a prompt row has no ai_model / temperature linked.
# After `setup_ai_models` + `setup_resume_job_evaluation`, you normally leave these unset.
# GEMINI_RESUME_JOB_EVAL_MODEL=gemini-2.5-flash
# GEMINI_RESUME_JOB_EVAL_TEMPERATURE=0.35

## DeepSeek (catalog in admin — API client not wired yet)
# API key: https://platform.deepseek.com/api_keys
# Base URL for Chat Completions: https://api.deepseek.com (OpenAI-compatible SDK)
# Model ids (seeded by setup_ai_models): deepseek-v4-pro, deepseek-v4-flash
# Legacy aliases (deprecated 2026-07-24): deepseek-chat, deepseek-reasoner
DEEPSEEK_API_KEY=

## Email / notifications
SENDGRID_MAIL_ACCESS=SG...
FROM_EMAIL=JOBEAS <support@jobeas.com>
ADMIN_EMAIL=admin@jobeas.com
SITE_URL=http://localhost:8000
EMAIL_TEST_RECIPIENT=you@example.com

## Stripe
MYAPP_STRIPE_SECRET_KEY=sk_test_...
MYAPP_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_BILLING_CURRENCY=usd

# Optional: only if checkout falls back to inline price_data (invalid Price ID). Prefer a Product ID from your Stripe catalog.
# STRIPE_FALLBACK_PRODUCT_ID=prod_...

# Default currency for provision_stripe_catalog (also used as --currency default)
STRIPE_PROVISION_CURRENCY=usd

# Optional — picked up by setup_subscription_plans (e.g. Cloud Run after migrate) so DB stripe_price_id
# matches your Stripe catalog without running provision on the server:
# STRIPE_PLUS_WEEKLY_PRICE_ID=price_...
# STRIPE_PLUS_MONTHLY_PRICE_ID=price_...
# STRIPE_ULTIMATE_WEEKLY_PRICE_ID=price_...
# STRIPE_ULTIMATE_MONTHLY_PRICE_ID=price_...
# STRIPE_TEST_WEEKLY_PRICE_ID=price_...
# STRIPE_TEST_MONTHLY_PRICE_ID=price_...

# Optional FX display hints used by subscriptions pricing display
# Example: if 1 MXN ~= 0.074 CAD and 0.059 USD
PRICING_APPROX_CAD_PER_MXN=
PRICING_APPROX_USD_PER_MXN=

# Optional Stripe catalog provisioning command vars (local/CI; not used by entrypoint.sh)
STRIPE_DESTINATION_SECRET_KEY=sk_test_...
STRIPE_SOURCE_SECRET_KEY=sk_test_...

## Google Cloud Storage (resume profile images)
#
# The wizard only uploads a portrait when the selected template supports profile photos
# (currently "Creative Studio"; see template_registry._TEMPLATE_CAPABILITY_OVERRIDES).
#
# For objects to land in the bucket (not local MEDIA), ALL of the following must hold:
# - ENABLE_GCS_PROFILE_UPLOAD=true
# - GS_BUCKET_NAME set to your bucket id
# - google-cloud-storage installed in the SAME Python env as the app (pip/poetry)
# - Credentials Application Default Credentials locally (e.g. GOOGLE_APPLICATION_CREDENTIALS) or workload identity on Cloud Run
#
# Bucket name only (required once uploads are wired). Use same region idea as Cloud Run / DB where possible.
GS_BUCKET_NAME=your-project-resume-uploads
#
# Local development only — absolute path to a service-account JSON key for a minimally privileged SA (never commit keys).
# On Cloud Run, leave this unset: attach an SA with storage access to the service and use workload identity ADC.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-gcs-dev-sa-key.json
#
# Optional — some client libs want an explicit project; often inferred automatically.
GCP_PROJECT_ID=your-gcp-project-id
#
# Toggle when code supports it — false falls back to local MEDIA storage for profile photos during dev.
ENABLE_GCS_PROFILE_UPLOAD=false
